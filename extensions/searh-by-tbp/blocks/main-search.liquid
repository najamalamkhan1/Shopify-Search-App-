{
"name": "TBP Search Page",
"target": "section",
"settings": [
{
"type": "header",
"content": "1. General options"
},
{
"type": "text",
"id": "whatsapp_number",
"label": "WhatsApp number (for $0 / price-on-request products)",
"info": "International format, digits only no +, spaces or dashes. e.g. 923001234567",
"default": "923001234567"
}
]
}
{% endschema %}

